<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/textView7999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/passwordentryfield"
            app:layout_constraintHorizontal_bias="0.01"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView23999"
            app:layout_constraintVertical_bias="0.0" />

        <TextView
            android:id="@+id/textView8999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Confirm Password:"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView7999"
            app:layout_constraintVertical_bias="0.0" />

        <EditText
            android:id="@+id/passwordentryfield"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:ems="10"
            android:inputType="textPassword"
            android:text="enteryourpassword"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/textView7999"
            app:layout_constraintTop_toBottomOf="@+id/textView23999" />

        <Button
            android:id="@+id/button9999"
            android:layout_width="0dp"
            android:layout_height="47dp"
            android:text="Back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/button10999"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/button10999"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:text="Next"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@+id/button9999" />

        <TextView
            android:id="@+id/textView23999"
            android:layout_width="413dp"
            android:layout_height="85dp"
            android:text="Configure a password that you will use to sign in to your account.Please remember this password"
            android:textAlignment="textStart"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar9" />

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar9"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="1dp"
            android:background="?attr/colorPrimary"
            android:minHeight="?attr/actionBarSize"
            android:theme="?attr/actionBarTheme"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/passwordconfirmationfield"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="2dp"
            android:ems="10"
            android:inputType="textPassword"
            android:text="enteryourpassword"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/textView8999"
            app:layout_constraintTop_toBottomOf="@+id/passwordentryfield" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>